{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "dpcab-mcp",
      "version": "0.1.0",
      "title": "DPCAB HR Analytics MCP"
    },
    "tools": [
      {
        "name": "list_grupos_kpi",
        "title": "List KPIs by cargo group",
        "description": "Returns admissions, rescissions, chamamentos and net balance aggregated by canonical cargo group.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Maximum number of groups to return (default 50).",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_secretarias_kpi",
        "title": "List KPIs by secretariat",
        "description": "Returns admissions, rescissions and chamamentos aggregated by canonical secretariat.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Maximum number of secretariats to return (default 50).",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 500
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
